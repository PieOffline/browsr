<Window x:Class="ProPilot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:ProPilot.ViewModels"
        xmlns:views="clr-namespace:ProPilot.Views"
        xmlns:converters="clr-namespace:ProPilot.Converters"
        mc:Ignorable="d"
        Title="ProPilot"
        Height="700" Width="1100"
        MinHeight="550" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BaseBgBrush}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolConverter x:Key="InverseBool" />

        <!-- DataTemplate mapping ViewModels to Views -->
        <DataTemplate DataType="{x:Type vm:ChatViewModel}">
            <views:ChatView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AssignmentsViewModel}">
            <views:AssignmentsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DocumentsViewModel}">
            <views:DocumentsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>

        <!-- Pill tab button style -->
        <Style x:Key="PillTabButton" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabBorder" Background="Transparent" CornerRadius="999"
                                Padding="16,8" Cursor="Hand" SnapsToDevicePixels="True">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon x:Name="TabIcon" Width="18" Height="18"
                                    Kind="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                    VerticalAlignment="Center" Foreground="#AAAAAA" />
                                <TextBlock x:Name="TabLabel" Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                                           Margin="6,0,0,0" FontSize="13" FontWeight="Medium"
                                           VerticalAlignment="Center" Foreground="#AAAAAA" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource AccentGradientHorizontal}" />
                                <Setter TargetName="TabIcon" Property="Foreground" Value="White" />
                                <Setter TargetName="TabLabel" Property="Foreground" Value="White" />
                                <Setter TargetName="TabBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#6C63FF" BlurRadius="12" ShadowDepth="0" Opacity="0.4" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="#22FFFFFF" />
                                <Setter TargetName="TabIcon" Property="Foreground" Value="White" />
                                <Setter TargetName="TabLabel" Property="Foreground" Value="White" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Onboarding overlay -->
        <views:OnboardingView DataContext="{Binding OnboardingVm}"
                              Visibility="{Binding DataContext.ShowOnboarding, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"
                              Panel.ZIndex="100" />

        <!-- Main app layout -->
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowOnboarding}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top Navigation Bar -->
            <Border Grid.Row="0" Padding="0,12" Background="{StaticResource PanelBgBrush}">
                <Grid>
                    <!-- App branding left -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="20,0,0,0" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="RobotHappy" Width="24" Height="24" Foreground="{StaticResource AccentGradientHorizontal}" VerticalAlignment="Center" />
                        <TextBlock Text="ProPilot" FontSize="16" FontWeight="Bold" Margin="6,0,0,0"
                                   VerticalAlignment="Center" Foreground="White" />
                    </StackPanel>

                    <!-- Centred pill tab container -->
                    <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="#33FFFFFF" CornerRadius="999"
                            BorderBrush="#55FFFFFF" BorderThickness="1"
                            Padding="4">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="ChatTab" Style="{StaticResource PillTabButton}"
                                         Tag="Chat" Content="Chat" GroupName="NavTabs"
                                         IsChecked="{Binding IsChatActive, Mode=TwoWay}"
                                         Command="{Binding NavigateChatCommand}" />
                            <RadioButton x:Name="AssignmentsTab" Style="{StaticResource PillTabButton}"
                                         Tag="ClipboardText" Content="Assignments" GroupName="NavTabs"
                                         IsChecked="{Binding IsAssignmentsActive, Mode=TwoWay}"
                                         Command="{Binding NavigateAssignmentsCommand}" />
                            <RadioButton x:Name="DocumentsTab" Style="{StaticResource PillTabButton}"
                                         Tag="FileDocument" Content="Documents" GroupName="NavTabs"
                                         IsChecked="{Binding IsDocumentsActive, Mode=TwoWay}"
                                         Command="{Binding NavigateDocumentsCommand}" />
                            <RadioButton x:Name="SettingsTab" Style="{StaticResource PillTabButton}"
                                         Tag="Cog" Content="Settings" GroupName="NavTabs"
                                         IsChecked="{Binding IsSettingsActive, Mode=TwoWay}"
                                         Command="{Binding NavigateSettingsCommand}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Content area -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}" Margin="0" />
        </Grid>
    </Grid>
</Window>
