<UserControl x:Class="ProPilot.Views.DocumentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ProPilot.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <DockPanel Margin="16">
        <!-- Top bar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,16">
            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="UploadButton_Click" Padding="16,8">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Upload" VerticalAlignment="Center" />
                    <TextBlock Text="Upload Document" Margin="8,0,0,0" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Empty state -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Documents.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <materialDesign:PackIcon Kind="FileDocumentOutline" Width="64" Height="64"
                                      HorizontalAlignment="Center"
                                      Foreground="{DynamicResource MaterialDesignBodyLight}" />
            <TextBlock Text="No documents uploaded" FontSize="16" HorizontalAlignment="Center"
                       Margin="0,12,0,4" Foreground="{DynamicResource MaterialDesignBodyLight}" />
            <TextBlock Text="Upload a PDF or DOCX to get started" FontSize="13"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource MaterialDesignBodyLight}" />
        </StackPanel>

        <!-- Document list -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Documents}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Card Margin="0,0,0,8" Padding="16" UniformCornerRadius="10">
                            <DockPanel>
                                <!-- Actions on right -->
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" ToolTip="Open">
                                        <materialDesign:PackIcon Kind="OpenInNew" />
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" ToolTip="Delete">
                                        <materialDesign:PackIcon Kind="Delete" Foreground="IndianRed" />
                                    </Button>
                                </StackPanel>

                                <!-- File info -->
                                <StackPanel VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FilePdfBox" Width="20" Height="20"
                                                                  VerticalAlignment="Center"
                                                                  Foreground="{DynamicResource PrimaryHueMidBrush}">
                                            <materialDesign:PackIcon.Style>
                                                <Style TargetType="materialDesign:PackIcon">
                                                    <Setter Property="Kind" Value="FilePdfBox" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FileType}" Value="docx">
                                                            <Setter Property="Kind" Value="FileWordBox" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:PackIcon.Style>
                                        </materialDesign:PackIcon>
                                        <TextBlock Text="{Binding Filename}" FontSize="14" FontWeight="Medium"
                                                   VerticalAlignment="Center" Margin="8,0,0,0" />
                                    </StackPanel>
                                    <TextBlock FontSize="12" Margin="28,4,0,0"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}">
                                        <Run Text="Type:" />
                                        <Run Text="{Binding FileType, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </DockPanel>
                        </materialDesign:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
