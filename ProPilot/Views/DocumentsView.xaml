<UserControl x:Class="ProPilot.Views.DocumentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ProPilot.Converters"
             Background="{StaticResource BaseBgBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <DockPanel Margin="20,16">
        <!-- Top bar -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="Documents" FontSize="22" FontWeight="Bold" Foreground="White"
                       VerticalAlignment="Center" />
            <Button HorizontalAlignment="Right" DockPanel.Dock="Right"
                    Click="UploadButton_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{StaticResource AccentGradientHorizontal}"
                                CornerRadius="999" Padding="16,8" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Upload" VerticalAlignment="Center"
                                                          Width="16" Height="16" Foreground="White" />
                                <TextBlock Text="Upload Document" Margin="6,0,0,0" Foreground="White"
                                           FontWeight="Medium" FontSize="13" />
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DockPanel>

        <!-- Empty state -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Documents.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <materialDesign:PackIcon Kind="FileDocumentOutline" Width="64" Height="64"
                                      HorizontalAlignment="Center"
                                      Foreground="{StaticResource MutedTextBrush}" />
            <TextBlock Text="No documents uploaded" FontSize="16" HorizontalAlignment="Center"
                       Margin="0,12,0,4" Foreground="{StaticResource MutedTextBrush}" />
            <TextBlock Text="Upload a PDF or DOCX to get started" FontSize="13"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource MutedTextBrush}" />
        </StackPanel>

        <!-- Document list -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Documents}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8" Padding="16" CornerRadius="12"
                                Background="{StaticResource PanelBgBrush}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0" Color="#6C63FF" />
                            </Border.Effect>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                                                             To="0.25" Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                                                             To="0" Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <DockPanel>
                                <!-- Actions on right -->
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" ToolTip="Open" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent" Padding="6">
                                                    <materialDesign:PackIcon Kind="OpenInNew" Width="18" Height="18" Foreground="{StaticResource MutedTextBrush}" />
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" ToolTip="Delete" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent" Padding="6">
                                                    <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" Foreground="#FF6B6B" />
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>

                                <!-- File info -->
                                <StackPanel VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Width="20" Height="20"
                                                                  VerticalAlignment="Center"
                                                                  Foreground="{StaticResource AccentGradientHorizontal}">
                                            <materialDesign:PackIcon.Style>
                                                <Style TargetType="materialDesign:PackIcon">
                                                    <Setter Property="Kind" Value="FilePdfBox" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FileType}" Value="docx">
                                                            <Setter Property="Kind" Value="FileWordBox" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:PackIcon.Style>
                                        </materialDesign:PackIcon>
                                        <TextBlock Text="{Binding Filename}" FontSize="14" FontWeight="Medium"
                                                   VerticalAlignment="Center" Margin="8,0,0,0" Foreground="White" />
                                        <!-- File type badge -->
                                        <Border CornerRadius="999" Background="{StaticResource SurfaceBgBrush}"
                                                Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FileType, Mode=OneWay}" FontSize="10"
                                                       Foreground="{StaticResource MutedTextBrush}" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
