<UserControl x:Class="ProPilot.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ProPilot.Converters"
             Background="{StaticResource BaseBgBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="24,16">
        <StackPanel MaxWidth="550" HorizontalAlignment="Center">
            <!-- Your Profile Section -->
            <TextBlock Text="Your Profile" FontSize="20" FontWeight="Bold" Margin="0,0,0,12" Foreground="White" />
            <Border Padding="20" CornerRadius="16" Margin="0,0,0,24" Background="{StaticResource PanelBgBrush}">
                <StackPanel>
                    <TextBox materialDesign:HintAssist.Hint="Name"
                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12" FontSize="14" Foreground="White" />
                    <TextBox materialDesign:HintAssist.Hint="Email"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12" FontSize="14" Foreground="White" />
                    <TextBox materialDesign:HintAssist.Hint="School"
                             Text="{Binding School, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16" FontSize="14" Foreground="White" />
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding SaveCommand}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{StaticResource AccentGradientHorizontal}"
                                            CornerRadius="999" Padding="16,8">
                                        <TextBlock Text="Save Profile" Foreground="White" FontSize="13" FontWeight="Medium" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <TextBlock Text="{Binding SaveStatus}" VerticalAlignment="Center"
                                   Margin="12,0,0,0" FontSize="13" Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- AI Connection Section -->
            <TextBlock Text="AI Connection" FontSize="20" FontWeight="Bold" Margin="0,0,0,12" Foreground="White" />
            <Border Padding="20" CornerRadius="16" Margin="0,0,0,24" Background="{StaticResource PanelBgBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding MaskedKey}" FontSize="14" FontFamily="Consolas"
                               Margin="0,0,0,12"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <TextBox materialDesign:HintAssist.Hint="New API Key"
                             Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12" FontSize="14" Foreground="White" />
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding TestKeyCommand}" Cursor="Hand" Margin="0,0,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{StaticResource SurfaceBgBrush}"
                                            CornerRadius="999" Padding="16,8" BorderBrush="#33FFFFFF" BorderThickness="1">
                                        <TextBlock Text="Test Key" Foreground="White" FontSize="13" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Command="{Binding SaveCommand}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{StaticResource AccentGradientHorizontal}"
                                            CornerRadius="999" Padding="16,8">
                                        <TextBlock Text="Save" Foreground="White" FontSize="13" FontWeight="Medium" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="{Binding TestResult}" Margin="0,8,0,0" FontSize="13"
                               Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>
            </Border>

            <!-- Memory & Data Section -->
            <TextBlock Text="Memory &amp; Data" FontSize="20" FontWeight="Bold" Margin="0,0,0,12" Foreground="White" />
            <Border Padding="20" CornerRadius="16" Margin="0,0,0,24" Background="{StaticResource PanelBgBrush}">
                <StackPanel>
                    <TextBlock Text="All data is stored locally in the app's data/ folder. No data leaves your machine."
                               TextWrapping="Wrap" FontSize="13" Margin="0,0,0,12"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock Margin="0,0,0,16" FontSize="12" Foreground="{StaticResource MutedTextBrush}">
                        <Run Text="Path:" />
                        <Run Text="{Binding DataFolderPath, Mode=OneWay}" />
                    </TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding OpenDataFolderCommand}" Cursor="Hand" Margin="0,0,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{StaticResource SurfaceBgBrush}"
                                            CornerRadius="999" Padding="16,8" BorderBrush="#33FFFFFF" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="FolderOpen" Width="14" Height="14"
                                                                      Foreground="White" VerticalAlignment="Center" />
                                            <TextBlock Text="Open Data Folder" Foreground="White" FontSize="13" Margin="6,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Click="ResetButton_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#3C1B1B" CornerRadius="999" Padding="16,8"
                                            BorderBrush="#FF6B6B" BorderThickness="1">
                                        <TextBlock Text="Clear All Data" Foreground="#FF6B6B" FontSize="13" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- About Section -->
            <TextBlock Text="About" FontSize="20" FontWeight="Bold" Margin="0,0,0,12" Foreground="White" />
            <Border Padding="20" CornerRadius="16" Margin="0,0,0,24" Background="{StaticResource PanelBgBrush}">
                <StackPanel>
                    <TextBlock Text="ProPilot v2.0" FontSize="16" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="Your smart study co-pilot 🚀" FontSize="13"
                               Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
