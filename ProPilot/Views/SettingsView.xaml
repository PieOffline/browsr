<UserControl x:Class="ProPilot.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ProPilot.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="24,16">
        <StackPanel MaxWidth="550" HorizontalAlignment="Center">
            <!-- Profile Section -->
            <TextBlock Text="Profile" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
            <materialDesign:Card Padding="20" UniformCornerRadius="12" Margin="0,0,0,24">
                <StackPanel>
                    <TextBox materialDesign:HintAssist.Hint="Name"
                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12" />
                    <TextBox materialDesign:HintAssist.Hint="Email"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12" />
                    <TextBox materialDesign:HintAssist.Hint="School"
                             Text="{Binding School, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Save Profile" 
                                Command="{Binding SaveCommand}" Padding="16,8" />
                        <TextBlock Text="{Binding SaveStatus}" VerticalAlignment="Center"
                                   Margin="12,0,0,0" FontSize="13" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- API Key Section -->
            <TextBlock Text="API Key" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
            <materialDesign:Card Padding="20" UniformCornerRadius="12" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="{Binding MaskedKey}" FontSize="14" FontFamily="Consolas"
                               Margin="0,0,0,12"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" />
                    <TextBox materialDesign:HintAssist.Hint="New API Key"
                             Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                             
                             Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Test Key" 
                                Command="{Binding TestKeyCommand}" Padding="16,8"
                                Margin="0,0,12,0" />
                        <Button Content="Save" 
                                Command="{Binding SaveCommand}" Padding="16,8" />
                    </StackPanel>
                    <TextBlock Text="{Binding TestResult}" Margin="0,8,0,0" FontSize="13" />
                </StackPanel>
            </materialDesign:Card>

            <!-- Danger Zone -->
            <TextBlock Text="Danger Zone" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"
                       Foreground="IndianRed" />
            <materialDesign:Card Padding="20" UniformCornerRadius="12"
                                  Background="#2C1B1B">
                <StackPanel>
                    <TextBlock Text="Reset all data — this will delete your profile, all chats, assignments, and documents. This cannot be undone."
                               TextWrapping="Wrap" FontSize="13" Margin="0,0,0,16"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" />
                    <Button Content="Reset All Data"
                            Foreground="IndianRed" BorderBrush="IndianRed"
                            Click="ResetButton_Click" Padding="16,8" />
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>
