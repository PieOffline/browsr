<UserControl x:Class="ProPilot.Views.AssignmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ProPilot.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <!-- Assignment List -->
        <DockPanel>
            <DockPanel.Style>
                <Style TargetType="DockPanel">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowNewForm}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ShowDetail}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DockPanel.Style>

            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="16,12"
                        HorizontalAlignment="Right">
                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding ShowNewFormCommand}" Padding="16,8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" />
                        <TextBlock Text="New Assignment" Margin="8,0,0,0" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Empty state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Assignments.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <materialDesign:PackIcon Kind="ClipboardTextOutline" Width="64" Height="64"
                                          HorizontalAlignment="Center"
                                          Foreground="{DynamicResource MaterialDesignBodyLight}" />
                <TextBlock Text="No assignments yet" FontSize="16" HorizontalAlignment="Center"
                           Margin="0,12,0,4" Foreground="{DynamicResource MaterialDesignBodyLight}" />
                <TextBlock Text="Click 'New Assignment' to add one" FontSize="13"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesignBodyLight}" />
            </StackPanel>

            <!-- Assignment cards grid -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16,0">
                <ItemsControl ItemsSource="{Binding Assignments}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <materialDesign:Card Margin="8" Padding="16" Width="280"
                                                  UniformCornerRadius="12" Cursor="Hand"
                                                  MouseLeftButtonUp="AssignmentCard_Click">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontSize="13" Margin="0,4,0,0"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}">
                                        <Run Text="{Binding Subject}" /> — <Run Text="{Binding ClassName}" />
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <materialDesign:PackIcon Kind="CalendarClock" Width="16" Height="16"
                                                                  VerticalAlignment="Center"
                                                                  Foreground="{DynamicResource MaterialDesignBodyLight}" />
                                        <TextBlock Text="{Binding Deadline}" FontSize="12" Margin="4,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}" />
                                    </StackPanel>
                                </StackPanel>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- New Assignment Form -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding ShowNewForm, Converter={StaticResource BoolToVis}}">
            <StackPanel MaxWidth="550" Margin="24,16" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            Command="{Binding CloseFormCommand}">
                        <materialDesign:PackIcon Kind="ArrowLeft" />
                    </Button>
                    <TextBlock Text="New Assignment" FontSize="22" FontWeight="Medium"
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>

                <!-- Screenshot area -->
                <materialDesign:Card Padding="16" Margin="0,0,0,16" UniformCornerRadius="12">
                    <StackPanel>
                        <TextBlock Text="Import from Screenshot" FontWeight="Medium" FontSize="14"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="Paste a screenshot (Ctrl+V) or drag &amp; drop an image, then click Analyse"
                                   FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   Margin="0,0,0,12" TextWrapping="Wrap" />
                        <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1"
                                CornerRadius="8" MinHeight="100" Margin="0,0,0,8"
                                AllowDrop="True" Drop="ScreenshotDrop" DragOver="ScreenshotDragOver"
                                Background="Transparent" x:Name="ScreenshotDropArea">
                            <TextBlock Text="Paste or drop screenshot here"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}" />
                        </Border>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Analyse" Style="{StaticResource MaterialDesignRaisedButton}"
                                    Command="{Binding AnalyseScreenshotCommand}" Padding="16,8" />
                            <TextBlock Text="{Binding AnalyseStatus}" VerticalAlignment="Center"
                                       Margin="12,0,0,0" FontSize="13" />
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Form fields -->
                <TextBox materialDesign:HintAssist.Hint="Title"
                         Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,12" />
                <TextBox materialDesign:HintAssist.Hint="Subject"
                         Text="{Binding NewSubject, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,12" />
                <TextBox materialDesign:HintAssist.Hint="Class Name"
                         Text="{Binding NewClassName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,12" />
                <TextBox materialDesign:HintAssist.Hint="Description"
                         Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"
                         Margin="0,0,0,12" />
                <TextBox materialDesign:HintAssist.Hint="Brief"
                         Text="{Binding NewBrief, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                         Margin="0,0,0,12" />
                <TextBox materialDesign:HintAssist.Hint="Deadline (e.g., 2025-03-15)"
                         Text="{Binding NewDeadline, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,24" />

                <Button Content="Save Assignment" Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding SaveAssignmentCommand}"
                        HorizontalAlignment="Center" Padding="32,8" FontSize="14" />
            </StackPanel>
        </ScrollViewer>

        <!-- Assignment Detail -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding ShowDetail, Converter={StaticResource BoolToVis}}">
            <StackPanel MaxWidth="550" Margin="24,16" HorizontalAlignment="Center"
                        DataContext="{Binding}">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            Command="{Binding BackToListCommand}">
                        <materialDesign:PackIcon Kind="ArrowLeft" />
                    </Button>
                    <TextBlock Text="{Binding SelectedAssignment.Title}" FontSize="22" FontWeight="Medium"
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>

                <materialDesign:Card Padding="20" UniformCornerRadius="12">
                    <StackPanel>
                        <TextBlock FontSize="14" Margin="0,0,0,8">
                            <Run Text="Subject:" FontWeight="SemiBold" />
                            <Run Text="{Binding SelectedAssignment.Subject}" />
                        </TextBlock>
                        <TextBlock FontSize="14" Margin="0,0,0,8">
                            <Run Text="Class:" FontWeight="SemiBold" />
                            <Run Text="{Binding SelectedAssignment.ClassName}" />
                        </TextBlock>
                        <TextBlock FontSize="14" Margin="0,0,0,8">
                            <Run Text="Deadline:" FontWeight="SemiBold" />
                            <Run Text="{Binding SelectedAssignment.Deadline}" />
                        </TextBlock>

                        <TextBlock Text="Description" FontWeight="SemiBold" FontSize="14" Margin="0,12,0,4" />
                        <TextBlock Text="{Binding SelectedAssignment.Description}" TextWrapping="Wrap"
                                   FontSize="13" Margin="0,0,0,12" />

                        <TextBlock Text="Brief" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding SelectedAssignment.Brief}" TextWrapping="Wrap"
                                   FontSize="13" Margin="0,0,0,16" />

                        <Button Content="Delete Assignment"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Command="{Binding DeleteAssignmentCommand}"
                                Foreground="IndianRed" BorderBrush="IndianRed"
                                HorizontalAlignment="Left" Padding="16,6" />
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
