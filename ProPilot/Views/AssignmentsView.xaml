<UserControl x:Class="ProPilot.Views.AssignmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ProPilot.Converters"
             Background="{StaticResource BaseBgBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <!-- Assignment List -->
        <DockPanel>
            <DockPanel.Style>
                <Style TargetType="DockPanel">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowNewForm}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ShowDetail}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DockPanel.Style>

            <DockPanel DockPanel.Dock="Top" Margin="20,16,20,12">
                <TextBlock Text="Assignments" FontSize="22" FontWeight="Bold" Foreground="White"
                           VerticalAlignment="Center" />
                <Button HorizontalAlignment="Right" DockPanel.Dock="Right"
                        Command="{Binding ShowNewFormCommand}" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{StaticResource AccentGradientHorizontal}"
                                    CornerRadius="999" Padding="16,8" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center"
                                                              Width="16" Height="16" Foreground="White" />
                                    <TextBlock Text="New Assignment" Margin="6,0,0,0" Foreground="White"
                                               FontWeight="Medium" FontSize="13" />
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </DockPanel>

            <!-- Empty state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Assignments.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <materialDesign:PackIcon Kind="ClipboardTextOutline" Width="64" Height="64"
                                          HorizontalAlignment="Center"
                                          Foreground="{StaticResource MutedTextBrush}" />
                <TextBlock Text="No assignments yet" FontSize="16" HorizontalAlignment="Center"
                           Margin="0,12,0,4" Foreground="{StaticResource MutedTextBrush}" />
                <TextBlock Text="Click 'New Assignment' to add one" FontSize="13"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}" />
            </StackPanel>

            <!-- Assignment cards grid -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16,0">
                <ItemsControl ItemsSource="{Binding Assignments}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="8" Width="280" CornerRadius="16" Cursor="Hand"
                                    Background="{StaticResource PanelBgBrush}"
                                    MouseLeftButtonUp="AssignmentCard_Click">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0" Color="#6C63FF" />
                                </Border.Effect>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="MouseEnter">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                                                                 To="0.35" Duration="0:0:0.2" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="MouseLeave">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                                                                 To="0" Duration="0:0:0.2" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                                <Grid>
                                    <!-- Gradient top accent -->
                                    <Border CornerRadius="16,16,0,0" Height="4" VerticalAlignment="Top"
                                            Background="{StaticResource AccentGradientHorizontal}" />
                                    <StackPanel Margin="16,16,16,16">
                                        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold"
                                                   TextTrimming="CharacterEllipsis" Foreground="White" />
                                        <!-- Subject pill chip -->
                                        <Border CornerRadius="999" Background="{StaticResource SurfaceBgBrush}"
                                                Padding="8,2" Margin="0,6,0,0" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Subject}" FontSize="11" Foreground="{StaticResource MutedTextBrush}" />
                                        </Border>
                                        <TextBlock FontSize="12" Margin="0,6,0,0" Foreground="{StaticResource MutedTextBrush}">
                                            <Run Text="{Binding ClassName, Mode=OneWay}" />
                                        </TextBlock>
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <materialDesign:PackIcon Kind="CalendarClock" Width="14" Height="14"
                                                                      VerticalAlignment="Center"
                                                                      Foreground="{StaticResource MutedTextBrush}" />
                                            <TextBlock Text="{Binding Deadline}" FontSize="12" Margin="4,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource MutedTextBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- New Assignment Form -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding ShowNewForm, Converter={StaticResource BoolToVis}}">
            <StackPanel MaxWidth="550" Margin="24,16" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Button Command="{Binding CloseFormCommand}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="4">
                                    <materialDesign:PackIcon Kind="ArrowLeft" Width="20" Height="20" Foreground="White" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock Text="New Assignment" FontSize="22" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="8,0,0,0" Foreground="White" />
                </StackPanel>

                <!-- Screenshot area -->
                <Border Padding="16" Margin="0,0,0,16" CornerRadius="16"
                        Background="{StaticResource PanelBgBrush}">
                    <StackPanel>
                        <TextBlock Text="Import from Screenshot" FontWeight="Bold" FontSize="14"
                                   Margin="0,0,0,8" Foreground="White" />
                        <TextBlock Text="Paste a screenshot (Ctrl+V) or drag &amp; drop an image, then click Analyse"
                                   FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,0,0,12" TextWrapping="Wrap" />
                        <Border BorderThickness="1"
                                CornerRadius="12" MinHeight="100" Margin="0,0,0,8"
                                AllowDrop="True" Drop="ScreenshotDrop" DragOver="ScreenshotDragOver"
                                Background="Transparent" x:Name="ScreenshotDropArea">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#55FFFFFF" />
                            </Border.BorderBrush>
                            <TextBlock Text="Paste or drop screenshot here"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedTextBrush}" />
                        </Border>
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding AnalyseScreenshotCommand}" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="AnalyseBd" Background="{StaticResource AccentGradientHorizontal}"
                                                CornerRadius="999" Padding="16,8" Cursor="Hand">
                                            <TextBlock Text="Analyse with AI ✨" Foreground="White" FontSize="13" FontWeight="Medium" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="AnalyseBd" Property="Opacity" Value="0.4" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <TextBlock Text="{Binding AnalyseStatus}" VerticalAlignment="Center"
                                       Margin="12,0,0,0" FontSize="13" Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Form fields -->
                <TextBox materialDesign:HintAssist.Hint="Title"
                         Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" FontSize="14" Foreground="White" />
                <TextBox materialDesign:HintAssist.Hint="Subject"
                         Text="{Binding NewSubject, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" FontSize="14" Foreground="White" />
                <TextBox materialDesign:HintAssist.Hint="Class Name"
                         Text="{Binding NewClassName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" FontSize="14" Foreground="White" />
                <TextBox materialDesign:HintAssist.Hint="Description"
                         Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"
                         Margin="0,0,0,12" FontSize="14" Foreground="White" />
                <TextBox materialDesign:HintAssist.Hint="Brief"
                         Text="{Binding NewBrief, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                         Margin="0,0,0,12" FontSize="14" Foreground="White" />
                <TextBox materialDesign:HintAssist.Hint="Deadline (e.g., 2025-03-15)"
                         Text="{Binding NewDeadline, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,24" FontSize="14" Foreground="White" />

                <Button Command="{Binding SaveAssignmentCommand}" HorizontalAlignment="Center" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{StaticResource AccentGradientHorizontal}"
                                    CornerRadius="999" Padding="32,10">
                                <TextBlock Text="Save Assignment 🎉" Foreground="White" FontSize="14" FontWeight="Medium" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </ScrollViewer>

        <!-- Assignment Detail -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding ShowDetail, Converter={StaticResource BoolToVis}}">
            <StackPanel MaxWidth="550" Margin="24,16" HorizontalAlignment="Center"
                        DataContext="{Binding}">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Button Command="{Binding BackToListCommand}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="4">
                                    <materialDesign:PackIcon Kind="ArrowLeft" Width="20" Height="20" Foreground="White" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock Text="{Binding SelectedAssignment.Title}" FontSize="22" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="8,0,0,0" Foreground="White" />
                </StackPanel>

                <Border Padding="20" CornerRadius="16" Background="{StaticResource PanelBgBrush}">
                    <StackPanel>
                        <TextBlock FontSize="14" Margin="0,0,0,8" Foreground="White">
                            <Run Text="Subject:" FontWeight="Bold" />
                            <Run Text="{Binding SelectedAssignment.Subject}" />
                        </TextBlock>
                        <TextBlock FontSize="14" Margin="0,0,0,8" Foreground="White">
                            <Run Text="Class:" FontWeight="Bold" />
                            <Run Text="{Binding SelectedAssignment.ClassName}" />
                        </TextBlock>
                        <TextBlock FontSize="14" Margin="0,0,0,8" Foreground="White">
                            <Run Text="Deadline:" FontWeight="Bold" />
                            <Run Text="{Binding SelectedAssignment.Deadline}" />
                        </TextBlock>

                        <TextBlock Text="Description" FontWeight="Bold" FontSize="14" Margin="0,12,0,4" Foreground="White" />
                        <TextBlock Text="{Binding SelectedAssignment.Description}" TextWrapping="Wrap"
                                   FontSize="13" Margin="0,0,0,12" Foreground="{StaticResource MutedTextBrush}" />

                        <TextBlock Text="Brief" FontWeight="Bold" FontSize="14" Margin="0,0,0,4" Foreground="White" />
                        <TextBlock Text="{Binding SelectedAssignment.Brief}" TextWrapping="Wrap"
                                   FontSize="13" Margin="0,0,0,16" Foreground="{StaticResource MutedTextBrush}" />

                        <Button Command="{Binding DeleteAssignmentCommand}" HorizontalAlignment="Left" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#3C1B1B" CornerRadius="999" Padding="16,6"
                                            BorderBrush="#FF6B6B" BorderThickness="1">
                                        <TextBlock Text="Delete Assignment" Foreground="#FF6B6B" FontSize="13" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
