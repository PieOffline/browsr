<UserControl x:Class="ProPilot.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ProPilot.Converters"
             Background="{StaticResource BaseBgBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:NullToVisibilityConverter x:Key="NullToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Session list panel -->
        <Border Grid.Column="0" Width="240" Background="{StaticResource PanelBgBrush}"
                CornerRadius="0,0,0,0"
                Visibility="{Binding ShowSessionList, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="12,16,12,8">
                    <TextBlock Text="Chats" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"
                               Foreground="White" />
                    <Button Margin="12,0,0,0" Command="{Binding NewSessionCommand}" ToolTip="New Chat"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{StaticResource AccentGradientHorizontal}"
                                        CornerRadius="999" Padding="10,4">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Plus" Width="14" Height="14" Foreground="White"
                                                                  VerticalAlignment="Center" />
                                        <TextBlock Text="New" FontSize="12" Foreground="White" Margin="4,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <ListBox ItemsSource="{Binding Sessions}"
                         SelectedItem="{Binding CurrentSession}"
                         Margin="8,0,8,8"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder" CornerRadius="12" Padding="10,8"
                                                Background="Transparent" Cursor="Hand">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SurfaceBgBrush}" />
                                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentGradientHorizontal}" />
                                                <Setter TargetName="ItemBorder" Property="BorderThickness" Value="2,0,0,0" />
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsMouseOver" Value="True" />
                                                    <Condition Property="IsSelected" Value="False" />
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#15FFFFFF" />
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        Command="{Binding DataContext.DeleteSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Width="22" Height="22" Padding="0" ToolTip="Delete"
                                        Opacity="0.5" Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Hidden" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <materialDesign:PackIcon Kind="Delete" Width="14" Height="14" Foreground="#FF6B6B" />
                                </Button>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                                               FontSize="13" Foreground="White" />
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Chat area -->
        <DockPanel Grid.Column="1" Background="{StaticResource BaseBgBrush}">
            <!-- Toggle session list button -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="12,8,12,0">
                <Button Command="{Binding ToggleSessionListCommand}" ToolTip="Toggle Sessions" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" Padding="4">
                                <materialDesign:PackIcon Kind="Menu" Width="20" Height="20" Foreground="{StaticResource MutedTextBrush}" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <!-- Input bar at bottom -->
            <Border DockPanel.Dock="Bottom" Padding="12,8" Margin="12,0,12,12"
                    CornerRadius="999" Background="{StaticResource PanelBgBrush}"
                    BorderBrush="#33FFFFFF" BorderThickness="1">
                <StackPanel>
                    <!-- Context chips -->
                    <WrapPanel Margin="0,0,0,4">
                        <!-- Linked assignment chips -->
                        <ItemsControl ItemsSource="{Binding LinkedAssignments}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="999" Padding="8,3" Margin="0,0,6,4"
                                            Background="#22FFFFFF" BorderBrush="{StaticResource AccentGradientHorizontal}"
                                            BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📖" FontSize="11" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Title}" FontSize="11" Foreground="White"
                                                       VerticalAlignment="Center" Margin="4,0,4,0" MaxWidth="120"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Button Command="{Binding DataContext.RemoveLinkedAssignmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" Width="14" Height="14" Padding="0" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <TextBlock Text="×" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Attached document chips -->
                        <ItemsControl ItemsSource="{Binding AttachedDocuments}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="999" Padding="8,3" Margin="0,0,6,4"
                                            Background="#22FFFFFF" BorderBrush="{StaticResource AccentGradientHorizontal}"
                                            BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📄" FontSize="11" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Filename}" FontSize="11" Foreground="White"
                                                       VerticalAlignment="Center" Margin="4,0,4,0" MaxWidth="120"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Button Command="{Binding DataContext.RemoveAttachedDocumentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" Width="14" Height="14" Padding="0" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <TextBlock Text="×" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </WrapPanel>

                    <DockPanel>
                        <!-- Send button (right) -->
                        <Button DockPanel.Dock="Right" Command="{Binding SendCommand}" ToolTip="Send"
                                Margin="8,0,0,0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="SendBd" Background="{StaticResource AccentGradientHorizontal}"
                                            CornerRadius="999" Padding="10,6" Cursor="Hand">
                                        <materialDesign:PackIcon Kind="Send" Width="18" Height="18" Foreground="White" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="SendBd" Property="Opacity" Value="0.4" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Text input -->
                        <TextBox Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Type a message..."
                                 AcceptsReturn="False" FontSize="14"
                                 VerticalContentAlignment="Center"
                                 Background="Transparent" Foreground="White"
                                 BorderThickness="0" CaretBrush="White"
                                 KeyDown="MessageBox_KeyDown" x:Name="MessageBox" />
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Typing indicator -->
            <Border DockPanel.Dock="Bottom" Margin="12,0,12,4"
                    Visibility="{Binding IsSending, Converter={StaticResource BoolToVis}}">
                <Border Background="#1E1E3A" CornerRadius="18,18,18,4" Padding="12,8"
                        HorizontalAlignment="Left" MaxWidth="100">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource MutedTextBrush}" Margin="2,0" />
                        <Ellipse Width="6" Height="6" Fill="{StaticResource MutedTextBrush}" Margin="2,0" />
                        <Ellipse Width="6" Height="6" Fill="{StaticResource MutedTextBrush}" Margin="2,0" />
                    </StackPanel>
                </Border>
            </Border>

            <!-- Messages area -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12,4,12,4"
                          x:Name="MessagesScroller">
                <ItemsControl ItemsSource="{Binding Messages}" Margin="0,0,0,8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="4,4" Padding="12,8" MaxWidth="600">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1E1E3A" />
                                        <Setter Property="HorizontalAlignment" Value="Left" />
                                        <Setter Property="CornerRadius" Value="18,18,18,4" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Role}" Value="user">
                                                <Setter Property="Background" Value="{StaticResource AccentGradient}" />
                                                <Setter Property="HorizontalAlignment" Value="Right" />
                                                <Setter Property="CornerRadius" Value="18,18,4,18" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="14" Foreground="White" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- Empty state when no session selected -->
        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding CurrentSession, Converter={StaticResource NullToVis}, ConverterParameter=Invert}">
            <materialDesign:PackIcon Kind="ChatOutline" Width="64" Height="64"
                                      HorizontalAlignment="Center"
                                      Foreground="{StaticResource MutedTextBrush}" />
            <TextBlock Text="Select a chat or start a new one"
                       FontSize="16" HorizontalAlignment="Center" Margin="0,12,0,0"
                       Foreground="{StaticResource MutedTextBrush}" />
        </StackPanel>
    </Grid>
</UserControl>
